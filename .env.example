# ====== 阿里云 DashScope（语音识别 ASR）======
DASHSCOPE_API_KEY=

# ====== 阿里云 OSS（临时存储音频供 ASR 访问）======
OSS_REGION=oss-cn-beijing
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET=

# ====== LLM 配置 ======
LLM_PROVIDER=dashscope
DASHSCOPE_LLM_MODEL=qwen-plus

# ====== 应用配置 ======
OUTPUT_DIR=./output
TEMP_DIR=./temp

# ====== 如果需要将 md 文件同步到 Obsidian 请配置仓库路径 ======
OBSIDIAN_VAULT_PATH=
