# ====== 阿里云 DashScope（语音识别 ASR + 通义千问 LLM）======
DASHSCOPE_API_KEY=sk-******************

# ====== LLM 配置 ======
LLM_PROVIDER=dashscope
DASHSCOPE_LLM_MODEL=qwen-plus

# ====== 阿里云 OSS（临时存储音频供 ASR 访问）======
OSS_REGION=oss****ing
OSS_ACCESS_KEY_ID=LTAI*******qasa
OSS_ACCESS_KEY_SECRET=*****************
OSS_BUCKET=*****************

# ====== 应用配置 ======
OUTPUT_DIR=./output
TEMP_DIR=./temp
# 邀请码（可选，不设置则首次启动自动生成随机码）
INVITE_CODE=AI-TOOLBOX-2026

# ====== 如果需要将 md 文件同步到 Obsidian 请配置仓库路径======
OBSIDIAN_VAULT_PATH=/Users/..../Obsidian Vault

# ====== 飞书多维表格 ======
FEISHU_APP_ID=*****************
FEISHU_APP_SECRET=*****************







